{
  "name": "oneproxy-vscode",
  "displayName": "OneProxy",
  "description": "Connect VS Code Remote-SSH through OneProxy access paths.",
  "version": "2.1.20",
  "publisher": "oneproxy",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Remote"
  ],
  "activationEvents": [
    "onCommand:oneproxy.login",
    "onCommand:oneproxy.selectSshTarget",
    "onCommand:oneproxy.writeSshConfig",
    "onCommand:oneproxy.connectRemoteSsh",
    "onCommand:oneproxy.setSshProxyMode"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "oneproxy.login",
        "title": "OneProxy: Login"
      },
      {
        "command": "oneproxy.selectSshTarget",
        "title": "OneProxy: Select SSH Target"
      },
      {
        "command": "oneproxy.writeSshConfig",
        "title": "OneProxy: Write SSH Config"
      },
      {
        "command": "oneproxy.connectRemoteSsh",
        "title": "OneProxy: Connect with Remote-SSH"
      },
      {
        "command": "oneproxy.setSshProxyMode",
        "title": "OneProxy: Set SSH Proxy Mode"
      }
    ],
    "configuration": {
      "title": "OneProxy",
      "properties": {
        "oneproxy.cliPath": {
          "type": "string",
          "default": "oneproxy",
          "description": "Path to the oneproxy CLI."
        },
        "oneproxy.sshConfigHostPrefix": {
          "type": "string",
          "default": "oneproxy",
          "description": "Prefix for SSH host aliases managed by OneProxy."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "typescript": "^6.0.3"
  }
}
