{
  "manifest_version": 3,
  "name": "One Proxy",
  "version": "0.3.6",
  "default_locale": "en",
  "description": "__MSG_appDescription__",
  "permissions": [
    "alarms",
    "proxy",
    "storage",
    "tabs",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/one-proxy-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/status-bubble.js"
      ],
      "css": [
        "content/status-bubble.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/logo/logo-16.png",
    "32": "assets/logo/logo-32.png",
    "48": "assets/logo/logo-48.png",
    "128": "assets/logo/logo-128.png"
  },
  "action": {
    "default_title": "One Proxy",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/logo/logo-16.png",
      "32": "assets/logo/logo-32.png"
    }
  },
  "options_page": "options/index.html"
}
