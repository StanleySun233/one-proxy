{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vscode"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "../one-proxy-panel/node_modules/@types"
    ]
  },
  "include": [
    "src"
  ]
}
